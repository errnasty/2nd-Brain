#DATABASE_URL=postgresql://postgres.umwgrjeghufbdqisgzqy:.7r2G.VQb9%21Nr%2FL@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.umwgrjeghufbdqisgzqy:.7r2G.VQb9%21Nr%2FL@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres
# --- LLM Providers ---
ANTHROPIC_API_KEY=sk-ant-...
# Anthropic does NOT provide an embeddings API. The app uses OpenAI embeddings
# by default. Voyage AI is Anthropic's recommended embeddings partner if you
# prefer to stay in the Anthropic ecosystem.
OPENAI_API_KEY=sk-...
# VOYAGE_API_KEY=pa-...

# Embeddings provider: "openai" (default) | "voyage" | "ollama"
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=text-embedding-3-small

# Optional: local Ollama for chat completion (set base URL if running locally)
# OLLAMA_BASE_URL=http://localhost:11434

# --- Cron / Edge ---
# Secret used by /api/cron/* routes to authorize Vercel Cron invocations.
CRON_SECRET=generate-a-random-string

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
