# --- Supabase ---
# Find these at: Supabase dashboard → your project → Connect button (top center) → URI tab
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Database (Drizzle / direct Postgres) ---
# For local dev / migrations: use the Direct connection (port 5432)
# For production (Netlify env var): use the Transaction pooler (port 6543)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres
# --- LLM Providers ---
ANTHROPIC_API_KEY=sk-ant-...
# Anthropic does NOT provide an embeddings API. The app uses OpenAI embeddings
# by default. Voyage AI is Anthropic's recommended embeddings partner if you
# prefer to stay in the Anthropic ecosystem.
OPENAI_API_KEY=sk-...
# VOYAGE_API_KEY=pa-...

# Embeddings provider: "openai" (default) | "voyage" | "ollama"
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=text-embedding-3-small

# Optional: local Ollama for chat completion (set base URL if running locally)
# OLLAMA_BASE_URL=http://localhost:11434

# --- Cron / Edge ---
# Secret used by /api/cron/* routes to authorize Vercel Cron invocations.
CRON_SECRET=generate-a-random-string

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
