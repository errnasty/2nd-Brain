# --- Supabase ---
# Find these at: Supabase dashboard → your project → Connect button (top center) → URI tab
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Database (Drizzle / direct Postgres) ---
# For local dev / migrations: use the Direct connection (port 5432)
# For production (Netlify env var): use the Transaction pooler (port 6543)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres
# --- LLM Providers ---
# Anthropic Claude is used for the Daily Brief and chat completions.
# Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Embeddings: Anthropic does not provide an embeddings API. Pick one:
#   - Voyage AI (Anthropic's documented partner) → keep EMBEDDINGS_PROVIDER=voyage
#   - OpenAI                                      → set EMBEDDINGS_PROVIDER=openai
#   - local (offline, @xenova/transformers)      → set EMBEDDINGS_PROVIDER=local
#       Runs bge-large-en-v1.5 (1024 dims) in-process with no network. Best for
#       local dev / air-gapped use. Switching providers requires re-embedding
#       the whole library (clear embeddings + POST /api/embeddings/backfill),
#       because vectors from different models are not comparable.
EMBEDDINGS_PROVIDER=voyage
VOYAGE_API_KEY=pa-...
# Default model: voyage-3-large (1024 dims native, matches our pgvector column).
# Set EMBEDDINGS_MODEL to override (voyage-3, voyage-3.5, voyage-3-large, etc.)
# EMBEDDINGS_MODEL=voyage-3-large

# OpenAI alternative — only set both of these if EMBEDDINGS_PROVIDER=openai:
# OPENAI_API_KEY=sk-...
# EMBEDDINGS_MODEL=text-embedding-3-small

# Optional: local Ollama for chat completion (set base URL if running locally)
# OLLAMA_BASE_URL=http://localhost:11434

# OpenAI key is also used for the GPT-4o option in the Ask tab's model picker.
# OPENAI_API_KEY=sk-...

# --- Cron / Edge ---
# Secret used by /api/cron/* and /api/embeddings/cron-backfill to authorize
# GitHub-Actions cron invocations (Authorization: Bearer $CRON_SECRET).
CRON_SECRET=generate-a-random-string

# --- Invite-only signup (optional, for multi-user self-hosting) ---
# When set, /signup requires this code and creates accounts server-side with
# the service-role key (email pre-confirmed). ALSO turn OFF "Allow new users
# to sign up" in Supabase → Authentication → Sign In / Up, otherwise the
# public anon-key signup endpoint still accepts direct requests.
# SIGNUP_INVITE_CODE=pick-a-code-to-share-with-invitees

# --- Daily AI token budget (optional, recommended for multi-user) ---
# Caps each user's cumulative AI token spend per UTC day across Ask, the
# Daily Brief, document Q&A, rabbitholes, and follow-up suggestions. Over
# budget, those routes return 429 until midnight UTC. Unset/0 = unlimited.
# AI_DAILY_TOKEN_BUDGET=500000

# --- MCP server (/api/mcp) ---
# Lets external Claude Desktop/mobile clients read your Second Brain.
# MCP_TOKEN: secret sent as the X-MCP-Token header by the client.
# MCP_USER_EMAIL: which account's brain to expose (matched against profiles.email).
#   Optional if you only have one account.
# MCP_TOKEN=generate-a-random-string
# MCP_USER_EMAIL=you@example.com

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
