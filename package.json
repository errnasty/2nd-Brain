{
  "name": "second-brain",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "node scripts/inject-sw-buildid.mjs",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:local-schema": "drizzle-kit generate --name local_schema && node electron/bundle-local-schema.js",
    "test": "node scripts/vitest.mjs run",
    "test:watch": "node scripts/vitest.mjs",
    "desktop:dev": "electron .",
    "desktop:build": "node electron/build.js",
    "desktop:fix": "node electron/fix-binary.js",
    "desktop:icons": "node electron/make-icons.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@anthropic-ai/sdk": "^0.100.1",
    "@dnd-kit/core": "^6.3.1",
    "@electric-sql/pglite": "^0.3.7",
    "@mozilla/readability": "^0.5.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-scroll-area": "^1.2.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.1",
    "@tanstack/react-virtual": "^3.13.26",
    "@xenova/transformers": "^2.17.2",
    "ai": "^4.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "dexie": "^4.4.3",
    "dexie-react-hooks": "^4.4.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.36.0",
    "fast-xml-parser": "^4.5.0",
    "jsdom": "^25.0.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.456.0",
    "next": "^15.0.3",
    "next-themes": "^0.4.3",
    "officeparser": "^7.1.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.1",
    "postgres": "^3.4.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.9",
    "remark-gfm": "^4.0.1",
    "rss-parser": "^3.13.0",
    "sanitize-html": "^2.17.4",
    "sonner": "^1.7.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.9.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.11.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "autoprefixer": "^10.4.20",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.28.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "electron-updater": "^6.8.9",
    "eslint": "^9",
    "eslint-config-next": "^15.0.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.7"
  },
  "build": {
    "appId": "com.secondbrain.desktop",
    "productName": "Second Brain",
    "directories": {
      "output": "dist-desktop"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "REPLACE_WITH_GITHUB_USER",
        "repo": "2nd-Brain"
      }
    ],
    "files": [
      "electron/**/*",
      "package.json",
      "!node_modules/**/*",
      "node_modules/argparse/**/*",
      "node_modules/builder-util-runtime/**/*",
      "node_modules/debug/**/*",
      "node_modules/electron-updater/**/*",
      "node_modules/fs-extra/**/*",
      "node_modules/graceful-fs/**/*",
      "node_modules/js-yaml/**/*",
      "node_modules/jsonfile/**/*",
      "node_modules/lazy-val/**/*",
      "node_modules/lodash.escaperegexp/**/*",
      "node_modules/lodash.isequal/**/*",
      "node_modules/ms/**/*",
      "node_modules/sax/**/*",
      "node_modules/semver/**/*",
      "node_modules/tiny-typed-emitter/**/*",
      "node_modules/universalify/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "app/.next/standalone"
      },
      {
        "from": ".next/standalone/node_modules",
        "to": "app/.next/standalone/node_modules"
      },
      {
        "from": ".next/static",
        "to": "app/.next/standalone/.next/static"
      },
      {
        "from": "public",
        "to": "app/.next/standalone/public"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "build/icon.png"
    }
  }
}
